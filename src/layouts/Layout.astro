---
import '../styles/global.css';
interface Props {
  titulo: string;
  descricao?: string;
}
const { titulo, descricao = 'Dicas da comunidade Oxygen Club. As indicações são feitas pelos membros da comunidade. A Oxygen não se responsabiliza pela qualidade ou continuidade dos serviços indicados.' } = Astro.props;
const tituloFinal = titulo === 'Dicas' ? 'Dicas · Oxygen Club' : `${titulo} · Dicas Oxygen Club`;
// BASE_URL sem a barra final, pra juntar caminhos (`${base}/x`) sem gerar barra
// dupla quando o site roda na raiz (base '/'). `home` é o link da home: na raiz
// vira '/', em subpasta vira '/a-subpasta'.
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const home = base || '/';
// Mesmo endpoint (e mesmo padrão) usado em acesso.astro, pra manter os dois em
// sincronia. O portão abaixo revalida o acesso contra ele periodicamente.
const accessApi =
  import.meta.env.PUBLIC_ACCESS_API ||
  'https://admin.oxygenhub.com.br/api/dicas-access';
---
<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <!-- Portão de acesso (friction-level): redireciona quem ainda não validou o email
       para a página de acesso. Roda o mais cedo possível, antes do conteúdo, pra
       minimizar o flash. O conteúdo ainda chega ao navegador — é proposital.
       Além disso, revalida o email contra a API no máximo uma vez a cada 24h (TTL),
       pra que revogações de acesso (grupo removido no CursEduca) passem a valer em
       cerca de um dia. Erro de rede na revalidação falha aberto (não bloqueia). -->
  <script is:inline define:vars={{ base, accessApi }}>
    (function () {
      // TTL de 24h, casando com o snapshot diário do CursEduca.
      var TTL = 24 * 60 * 60 * 1000;
      try {
        // base pode vir com ou sem barra final; normaliza removendo a barra do fim.
        var raiz = base.replace(/\/$/, '');
        var rotaAcesso = raiz + '/acesso';
        var path = window.location.pathname.replace(/\/$/, '');
        // Já está na página de acesso? Não guarda/revalida (evita loop e flash).
        if (path === rotaAcesso) return;

        var acesso = localStorage.getItem('oxygenDicasAccess');
        var email = localStorage.getItem('oxygenDicasEmail');
        var checkedAt = parseInt(localStorage.getItem('oxygenDicasCheckedAt') || '', 10);

        // Caminho rápido: acesso liberado e validado há menos que o TTL.
        // Libera na hora, sem flash e sem fetch.
        if (acesso === '1' && checkedAt && (Date.now() - checkedAt) < TTL) return;

        // Sem email guardado não dá pra revalidar: manda pro portão.
        if (!email) {
          window.location.replace(rotaAcesso);
          return;
        }

        // Caminho lento (cache velho ou ausente): esconde o conteúdo enquanto
        // revalida, revelando de novo em caso de sucesso ou erro de rede.
        var root = document.documentElement;
        root.style.visibility = 'hidden';
        function revelar() {
          root.style.visibility = '';
        }

        fetch(accessApi, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: email }),
        })
          .then(function (res) {
            if (!res.ok) throw new Error('resposta não OK');
            return res.json();
          })
          .then(function (data) {
            if (data && data.eligible === true) {
              // Continua elegível: renova o timestamp e libera.
              localStorage.setItem('oxygenDicasAccess', '1');
              localStorage.setItem('oxygenDicasCheckedAt', String(Date.now()));
              revelar();
              return;
            }
            // Resposta explícita de não-elegível: revoga e volta pro portão.
            localStorage.removeItem('oxygenDicasAccess');
            localStorage.removeItem('oxygenDicasEmail');
            localStorage.removeItem('oxygenDicasCheckedAt');
            window.location.replace(rotaAcesso);
          })
          .catch(function () {
            // Erro de rede (não um "não-elegível" explícito): falha aberto pra
            // não trancar membros legítimos numa instabilidade da API. O snapshot
            // diário + a próxima revalidação bem-sucedida seguem valendo.
            revelar();
          });
      } catch (e) {
        // localStorage indisponível: não bloqueia o acesso.
      }
    })();
  </script>
  <title>{tituloFinal}</title>
  <meta name="description" content={descricao} />
  <meta property="og:title" content={tituloFinal} />
  <meta property="og:description" content={descricao} />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="pt_BR" />
  <link rel="icon" type="image/x-icon" href={`${base}/images/favicon.ico`} />
  <link rel="icon" type="image/png" sizes="32x32" href={`${base}/images/favicon-32.png`} />
  <link rel="icon" type="image/png" sizes="192x192" href={`${base}/images/favicon-192.png`} />
  <link rel="apple-touch-icon" sizes="180x180" href={`${base}/images/favicon-180.png`} />
  <link rel="manifest" href={`${base}/images/site.webmanifest`} />
  <meta name="theme-color" content="#e85a4f" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body>
  <header class="site-header">
    <div class="container">
      <div class="site-header-inner">
        <a href={home} class="site-logo">
          <img src={`${base}/images/logo-oxygen-club.png`} alt="Oxygen Club" />
        </a>
        <form class="site-search-form" action={`${base}/busca`} method="GET" role="search">
          <label class="site-search" for="busca">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="11" cy="11" r="8"/>
              <line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
            <input
              id="busca"
              name="q"
              type="search"
              placeholder="Buscar uma dica"
              autocomplete="off"
            />
          </label>
        </form>
      </div>
    </div>
  </header>
  <main>
    <slot />
  </main>
  <footer class="site-footer">
    <div class="container">
      <p>Feito com cuidado pela comunidade <a href="https://oxygenhub.com.br" target="_blank" rel="noopener">Oxygen Club</a></p>
    </div>
  </footer>
</body>
</html>
