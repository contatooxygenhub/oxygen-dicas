---
import '../styles/global.css';

interface Props {
  titulo: string;
  descricao?: string;
}

const { titulo, descricao = 'Dicas da comunidade Oxygen Club. Curadoria 100% humana.' } = Astro.props;

const tituloFinal = titulo === 'Dicas' ? 'Dicas · Oxygen Club' : `${titulo} · Dicas Oxygen Club`;

const base = import.meta.env.BASE_URL;
---
<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{tituloFinal}</title>
  <meta name="description" content={descricao} />

  <meta property="og:title" content={tituloFinal} />
  <meta property="og:description" content={descricao} />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="pt_BR" />

  <link rel="icon" type="image/png" href={`${base}/images/logo-oxygen-club.png`} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body>

  <header class="site-header">
    <div class="container">
      <div class="site-header-inner">
        <a href={base} class="site-logo">
          <img src={`${base}/images/logo-oxygen-club.png`} alt="Oxygen Club" />
        </a>

        <form class="site-search-form" action={`${base}/busca`} method="GET" role="search">
          <label class="site-search" for="busca">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="11" cy="11" r="8"/>
              <line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
            <input
              id="busca"
              name="q"
              type="search"
              placeholder="Buscar uma dica"
              autocomplete="off"
            />
          </label>
        </form>
      </div>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <div class="container">
      <p>Feito com cuidado pela comunidade <a href="https://oxygenhub.com.br" target="_blank" rel="noopener">Oxygen Club</a></p>
    </div>
  </footer>

</body>
</html>
