---
interface Props {
  href: string;
  categoria: string;
  subcategoria: string;
  titulo: string;
  descricao: string;
  meta?: string;
}

const { href, categoria, subcategoria, titulo, descricao, meta } = Astro.props;
---
<a href={href} class="card">
  <div class="card-top">
    <div>
      {meta && <div class="card-meta">{meta}</div>}
      <div class="card-titulo">{titulo}</div>
    </div>
    <span class="card-tag">{subcategoria}</span>
  </div>
  <div class="card-descricao">{descricao}</div>
</a>
