  especialidade?: string;
  contato?: string;
  pagamento?: string;
  faixa_preco?: string;
  indicado_por?: string;
  chef?: string;
  bairro?: string;
  instagram?: string;
  periodo_visita?: string;
  duracao_sugerida?: string;
