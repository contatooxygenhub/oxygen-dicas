const campos = camposPorSubcategoria[subcategoria] || [];
const camposPreenchidos = info ? campos.filter(c => info[c.chave]) : [];

function ehUrl(valor: string): boolean {
  return valor.startsWith('http://') || valor.startsWith('https://') || valor.includes('.com') || valor.includes('.br') || valor.includes('.pt') || valor.includes('.app') || valor.includes('.ai') || valor.includes('.io') || valor.includes('.net') || valor.includes('.org') || valor.includes('.za') || valor.includes('.hk') || valor.includes('.co');
}

function formatarLink(valor: string): string {
  if (valor.startsWith('http://') || valor.startsWith('https://')) return valor;
  return `https://${valor}`;
}

function instagramUrl(handle: string): string {
  const limpo = handle.replace(/^@/, '').trim();
  return `https://instagram.com/${limpo}`;
}

function telefoneLink(numero: string): string {
  const limpo = numero.replace(/[^\d+]/g, '');
  return `tel:${limpo}`;
}
---
{camposPreenchidos.length > 0 && info && (
  <div class="detalhe-info">
    <div class="detalhe-info-grid">
      {camposPreenchidos.map(campo => {
        const valor = info[campo.chave]!;
        return (
          <div class="detalhe-info-item">
            <div class="detalhe-info-label">{campo.label}</div>
            <div class="detalhe-info-value">
              {campo.eh_instagram ? (
                <a href={instagramUrl(valor)} target="_blank" rel="noopener noreferrer">
                  {valor.startsWith('@') ? valor : `@${valor}`} ↗
                </a>
              ) : campo.eh_telefone ? (
                <a href={telefoneLink(valor)}>{valor}</a>
              ) : campo.eh_link && ehUrl(valor) ? (
                <a href={formatarLink(valor)} target="_blank" rel="noopener noreferrer">
                  {valor.replace(/^https?:\/\//, '')} ↗
                </a>
              ) : (
                <span>{valor}</span>
              )}
            </div>
          </div>
        );
      })}
    </div>
  </div>
)}
