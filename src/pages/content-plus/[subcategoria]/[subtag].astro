---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import Card from '../../../components/Card.astro';
import { slugify, metaDoCard } from '../../../utils/helpers';

export async function getStaticPaths() {
  const dicas = await getCollection('dicas');
  const subs = ['Podcast', 'Filme', 'Série', 'Documentário', 'Livro'];

  const paths: any[] = [];
  for (const sub of subs) {
    const subtagsSet = new Set<string>();
    dicas
      .filter(d => d.data.categoria === 'Content+' && d.data.subcategoria === sub && d.data.subtag)
      .forEach(d => subtagsSet.add(d.data.subtag!));

    subtagsSet.forEach(subtag => {
      paths.push({
        params: { subcategoria: slugify(sub), subtag: slugify(subtag) },
        props: { subcategoria: sub, subtag }
      });
    });
  }
  return paths;
}

const { subcategoria, subtag } = Astro.props;
const base = import.meta.env.BASE_URL;

const dicas = (await getCollection('dicas'))
  .filter(d =>
    d.data.categoria === 'Content+' &&
    d.data.subcategoria === subcategoria &&
    d.data.subtag === subtag
  )
  .sort((a, b) => b.data.publicado_em.valueOf() - a.data.publicado_em.valueOf());
---
<Layout titulo={`${subcategoria} · ${subtag}`}>
  <div class="container">
    <nav class="breadcrumb" style="padding-top: 30px;">
      <a href={base}>Início</a>
      <span class="breadcrumb-sep">/</span>
      <a href={`${base}/content-plus`}>Content+</a>
      <span class="breadcrumb-sep">/</span>
      <a href={`${base}/content-plus/${slugify(subcategoria)}`}>{subcategoria}</a>
      <span class="breadcrumb-sep">/</span>
      <span class="breadcrumb-current">{subtag}</span>
    </nav>

    <section class="preambulo" style="padding-top: 30px;">
      <div class="preambulo-eyebrow">{subcategoria} · {subtag}</div>
      <h1 class="preambulo-titulo">{subcategoria}<br />{subtag.toLowerCase()}</h1>
      <p class="preambulo-texto">
        {dicas.length} {dicas.length === 1 ? 'dica' : 'dicas'} da comunidade.
      </p>
    </section>
  </div>

  <div class="container">
    <div class="filtros-wrap">
      {dicas.length > 0 && (
        <div class="cards-grid">
          {dicas.map(dica => (
            <Card
              href={`${base}/dicas/${dica.slug}`}
              categoria={dica.data.categoria}
              subcategoria={dica.data.subcategoria}
              titulo={dica.data.titulo}
              descricao={dica.data.subtitulo || ''}
              meta={metaDoCard(dica)}
            />
          ))}
        </div>
      )}
    </div>
  </div>
</Layout>
