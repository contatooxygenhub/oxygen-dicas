---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Card from '../components/Card.astro';
import { metaDoCard } from '../utils/helpers';

const base = import.meta.env.BASE_URL;

// Pega todas as dicas e passa pro frontend
const dicas = (await getCollection('dicas'))
  .sort((a, b) => b.data.publicado_em.valueOf() - a.data.publicado_em.valueOf())
  .map(d => ({
    slug: d.slug,
    titulo: d.data.titulo,
    subtitulo: d.data.subtitulo || '',
    categoria: d.data.categoria,
    subcategoria: d.data.subcategoria,
    subtag: d.data.subtag || '',
    pais: d.data.pais || '',
    cidade: d.data.cidade || '',
    tags: d.data.tags || [],
    meta: (() => {
      if (d.data.cidade && d.data.pais) return `${d.data.cidade}, ${d.data.pais}`;
      if (d.data.cidade) return d.data.cidade;
      if (d.data.pais) return d.data.pais;
      if (d.data.subtag) return d.data.subtag;
      return '';
    })(),
  }));
---
<Layout titulo="Buscar">
  <div class="container">
    <section class="preambulo" style="padding-top: 50px; padding-bottom: 30px;">
      <div class="preambulo-eyebrow">Busca</div>
      <h1 class="preambulo-titulo" id="titulo-busca">O que você procura?</h1>
      <p class="preambulo-texto" id="contador-busca">
        Digite na busca acima ou navegue pelas categorias.
      </p>
    </section>

    <div class="filtros-wrap" id="resultados-wrap" style="display: none;">
      <div class="cards-grid" id="resultados"></div>
    </div>

    <div class="empty" id="empty-busca" style="display: none;">
      Nenhuma dica encontrada. Tente outro termo ou explore as categorias.
    </div>
  </div>

  <script is:inline define:vars={{ dicas, base }}>
    function escapeHtml(s) {
      return String(s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
    }

    function renderCard(dica) {
      return `
        <a href="${base}/dicas/${dica.slug}" class="card">
          <div class="card-top">
            <div>
              ${dica.meta ? `<div class="card-meta">${escapeHtml(dica.meta)}</div>` : ''}
              <div class="card-titulo">${escapeHtml(dica.titulo)}</div>
            </div>
            <span class="card-tag">${escapeHtml(dica.subcategoria)}</span>
          </div>
          <div class="card-descricao">${escapeHtml(dica.subtitulo)}</div>
        </a>
      `;
    }

    function buscar(termo) {
      const t = termo.toLowerCase().trim();
      const titulo = document.getElementById('titulo-busca');
      const contador = document.getElementById('contador-busca');
      const wrap = document.getElementById('resultados-wrap');
      const grid = document.getElementById('resultados');
      const empty = document.getElementById('empty-busca');

      if (!t) {
        titulo.textContent = 'O que você procura?';
        contador.textContent = 'Digite na busca acima ou navegue pelas categorias.';
        wrap.style.display = 'none';
        empty.style.display = 'none';
        return;
      }

      const resultados = dicas.filter(d => {
        const texto = [
          d.titulo, d.subtitulo, d.categoria, d.subcategoria,
          d.subtag, d.pais, d.cidade, ...(d.tags || [])
        ].join(' ').toLowerCase();
        return texto.includes(t);
      });

      titulo.textContent = `Resultados para "${termo}"`;

      if (resultados.length === 0) {
        contador.textContent = 'Nada encontrado por aqui.';
        wrap.style.display = 'none';
        empty.style.display = 'block';
      } else {
        contador.textContent = `${resultados.length} ${resultados.length === 1 ? 'resultado' : 'resultados'}.`;
        grid.innerHTML = resultados.map(renderCard).join('');
        wrap.style.display = 'block';
        empty.style.display = 'none';
      }
    }

    // Pegar query da URL
    const url = new URL(window.location.href);
    const q = url.searchParams.get('q') || '';
    if (q) {
      buscar(q);
      const input = document.getElementById('busca');
      if (input) input.value = q;
    }
  </script>
</Layout>
